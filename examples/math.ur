shuro
  likho "#2 Math Operations Example"
  likho ""
  
  num1 = 10
  num2 = 5
  
  likho "Numbers: " num1 " aur " num2
  likho ""
  
  sum = num1 jodo num2
  likho "#3 Jodo (Addition): " sum
  
  diff = num1 ghatao num2
  likho "#4 Ghatao (Subtraction): " diff
  
  product = num1 gunaa num2
  likho "#5 Gunaa (Multiplication): " product
  
  division = num1 bhago num2
  likho "#6 Bhago (Division): " division
  
  likho ""
  likho "#2 Math operations complete!"
khatam
